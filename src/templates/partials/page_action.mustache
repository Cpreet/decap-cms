<!-- ===== PAGE: Get Help Now ===== -->
<div class="page" id="page-action">
    <div class="stories-hero" style="border-bottom:1px solid var(--border)">
        <div style="font-size:11px;font-weight:700;color:var(--primary);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:16px">Support &amp; Resources</div>
        <h1>Get Help Now</h1>
        <p style="color:var(--muted);font-size:16px;max-width:600px;line-height:1.7">Free legal aid, women's helplines, complaint portals, and mental health support. You do not have to face this alone.</p>
    </div>
    <div class="action-body">

        {{#has_legal_aid_helplines}}
        <div class="kyr-section-header action-section-header">
            <h2>Legal Aid</h2>
        </div>
        <div class="action-grid">
            {{#legal_aid_helplines}}
            <div class="legal-card">
                <h3>{{title}}</h3>
                <p>{{description}}</p>
                {{#phone}}
                <div class="legal-tag legal-tag-primary">Call: <strong>{{phone}}</strong></div>
                {{/phone}}
                {{#url}}
                <div class="legal-tag"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}} <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle">arrow_forward</span></a></div>
                {{/url}}
            </div>
            {{/legal_aid_helplines}}
        </div>
        {{/has_legal_aid_helplines}}

        {{#has_women_helplines}}
        <div class="kyr-section-header action-section-header action-section-break">
            <h2>Helplines</h2>
        </div>
        <div class="action-grid">
            {{#women_helplines}}
            <div class="legal-card">
                <h3>{{title}}</h3>
                <p>{{description}}</p>
                {{#phone}}
                <div class="legal-tag legal-tag-primary">Call: <strong>{{phone}}</strong></div>
                {{/phone}}
                {{#url}}
                <div class="legal-tag"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}} <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle">arrow_forward</span></a></div>
                {{/url}}
            </div>
            {{/women_helplines}}
        </div>
        {{/has_women_helplines}}

        {{#has_complaint_portals}}
        <div class="kyr-section-header action-section-header action-section-break">
            <h2>Complaint Portals</h2>
        </div>
        <div class="action-grid">
            {{#complaint_portals}}
            <div class="legal-card">
                <h3>{{title}}</h3>
                <p>{{description}}</p>
                {{#phone}}
                <div class="legal-tag legal-tag-primary">Call: <strong>{{phone}}</strong></div>
                {{/phone}}
                {{#url}}
                <div class="legal-tag"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}} <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle">arrow_forward</span></a></div>
                {{/url}}
            </div>
            {{/complaint_portals}}
        </div>
        {{/has_complaint_portals}}

        {{#has_mental_health_helplines}}
        <div class="kyr-section-header action-section-header action-section-break">
            <h2>Mental Health Support</h2>
        </div>
        <div class="action-grid">
            {{#mental_health_helplines}}
            <div class="legal-card">
                <h3>{{title}}</h3>
                <p>{{description}}</p>
                {{#phone}}
                <div class="legal-tag legal-tag-primary">Call: <strong>{{phone}}</strong></div>
                {{/phone}}
                {{#url}}
                <div class="legal-tag"><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}} <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle">arrow_forward</span></a></div>
                {{/url}}
            </div>
            {{/mental_health_helplines}}
        </div>
        {{/has_mental_health_helplines}}

    </div>
</div>
