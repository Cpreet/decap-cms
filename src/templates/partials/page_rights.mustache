<!-- ===== PAGE: KNOW YOUR RIGHTS ===== -->
<div class="page" id="page-rights">
    <div class="kyr-layout" style="flex:1">
        <!-- Sidebar -->
        <aside class="kyr-sidebar">
            <div class="sidebar-label">Legal Categories</div>
            {{#sidebar_links}}
            <a class="sidebar-link {{active_class}}" onclick="scrollKYR('{{anchor_id}}',this)">{{sidebar_label}}</a>
            {{/sidebar_links}}
            <a class="sidebar-link" onclick="scrollKYR('statelaws',this)">State-wise Laws</a>
        </aside>

        <!-- Main Content -->
        <main class="kyr-main">
            <div class="kyr-search">
                <span class="material-symbols-outlined" style="color:var(--muted);font-size:20px">search</span>
                <input type="text" placeholder="Search for 'security deposit', 'eviction', 'RWA'..." id="kyr-search-input" oninput="filterKYR(this.value)" />
            </div>

            <div class="kyr-disclaimer">
                <div class="kyr-disclaimer-title">
                    <span class="material-symbols-outlined" style="font-size:16px;color:var(--primary)">gavel</span>
                    Legal Disclaimer
                </div>
                <p>This page links to publicly available resources and provides brief summaries for awareness only. It is not legal advice and does not substitute for professional counsel. Laws change and individual circumstances vary — always verify with official sources and consult a qualified lawyer before making tenancy decisions. Rent Without Fear accepts no liability for actions taken based on this content.</p>
                <div class="kyr-disclaimer-meta">Last verified: April 12, 2026</div>
            </div>

            <!-- Legal Categories -->
            {{#legal_rights}}
            <section id="kyr-{{anchor_id}}" class="kyr-section">
                <div class="kyr-section-header">
                    <h2>{{category_title}}</h2>
                </div>
                {{#cards}}
                <div class="legal-card">
                    <h3>{{title}}</h3>
                    <p>{{body}}</p>
                    <div class="legal-tag">{{#source_url}}<span class="material-symbols-outlined" style="font-size:14px">open_in_new</span> <a href="{{source_url}}" target="_blank">{{legal_ref}} <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle">arrow_forward</span></a>{{/source_url}}{{^source_url}}<span class="material-symbols-outlined" style="font-size:14px">gavel</span> {{legal_ref}}{{/source_url}}</div>
                </div>
                {{/cards}}
            </section>
            {{/legal_rights}}

            <!-- State-wise Laws Widget -->
            <section id="kyr-statelaws" class="kyr-section state-widget-section">
                <h2>State-wise Rent Laws</h2>
                <p>India has no single national rent law. Each state has its own Act with different protections, caps, and procedures. Find yours below</p>
                <div id="state-widget-kyr"></div>
            </section>
        </main>
    </div>
</div>
